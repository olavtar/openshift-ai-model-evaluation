# Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Database Configuration
POSTGRES_DB=ai-quickstart-template
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://user:changeme@localhost:5432/ai-quickstart-template
DB_ECHO=false

# API Configuration
DEBUG=true
ALLOWED_HOSTS=["http://localhost:5173"]

# MaaS / model serving (required for queries, embeddings, eval scoring, question synthesis)
# The browser talks only to the FastAPI app; FastAPI calls MAAS_ENDPOINT from the server.
# Use the OpenAI-compatible base URL only (no trailing slash; /v1 is appended in code).
# Example LiteLLM front: https://litellm-prod-frontend.apps.maas.redhatworkshops.io
# Must match Settings.API_TOKEN in packages/api/src/core/config.py (not MODEL_API_TOKEN).
API_TOKEN=
MAAS_ENDPOINT=https://maas.apps.prod.rhoai.rh-aiservices-bu.com
# If embeddings go through LiteLLM and a client sends OpenAI "dimensions", enable drop_params
# on the LiteLLM proxy for Nomic (see litellm UnsupportedParamsError / GitHub #11940).
EMBEDDING_MODEL=

# Optional: model for "Generate from documents" (defaults to MODEL_A_NAME, then JUDGE_MODEL_NAME).
# Use this if your judge model is routed differently on LiteLLM (e.g. OAuth) but chat models work.
# QUESTION_SYNTHESIS_MODEL_NAME=
MODEL_A_NAME=
MODEL_B_NAME=
# LLM-as-judge for eval metrics (DeepEval). If empty, MODEL_A_NAME then MODEL_B_NAME are used.
JUDGE_MODEL_NAME=

# UI Configuration
VITE_API_BASE_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# OpenShift/Deployment Configuration
# These are used by make deploy
# REGISTRY_URL is auto-detected from oc registry info if not set
# REGISTRY_URL=default-route-openshift-image-registry.apps.example.com
NAMESPACE=ai-quickstart-template
IMAGE_TAG=latest
